<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- USER -->

        <TextView
            android:id="@+id/userName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lion"
            android:textColor="#FFD700"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <!-- WIDGETS -->

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/widgetRecycler"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="20dp"/>

        <!-- FILA 1 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">

            <!-- PAPELERA -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp">

                <ImageView
                    android:id="@+id/binApp"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/papelera"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Papelera"
                    android:textColor="#FFD700"/>
            </LinearLayout>

            <!-- ARCHIVOS -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp">

                <ImageView
                    android:id="@+id/filesApp"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/archivos"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Archivos"
                    android:textColor="#FFD700"/>
            </LinearLayout>

        </LinearLayout>

        <!-- FILA 2 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- STORE -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp">

                <ImageView
                    android:id="@+id/storeApp"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/storelion"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Store Lion"
                    android:textColor="#FFD700"/>
            </LinearLayout>

            <!-- CONFIG -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp">

                <ImageView
                    android:id="@+id/settingsApp"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/configuracion"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Configuración"
                    android:textColor="#FFD700"/>
            </LinearLayout>

        </LinearLayout>

        <!-- FILA 3 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- BROWSER -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp">

                <ImageView
                    android:id="@+id/browserApp"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/browser"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lion Browser"
                    android:textColor="#FFD700"/>
            </LinearLayout>

            <!-- MUSIC -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp">

                <ImageView
                    android:id="@+id/musicApp"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/music"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lion Music"
                    android:textColor="#FFD700"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>