<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#000000">

    <!-- TITULO -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configuración LionOS"
        android:textColor="#FFD700"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <!-- VERSION -->

    <TextView
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LionOS 1.0"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:padding="20dp"/>

    <!-- MENSAJE -->

    <TextView
        android:id="@+id/devMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFD700"
        android:textSize="18sp"
        android:layout_marginTop="20dp"/>

    <!-- PANEL SECRETO -->

    <LinearLayout
        android:id="@+id/devPanel"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gold"
        android:padding="20dp"
        android:visibility="gone"
        android:layout_marginTop="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛠 Developer Mode"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Admin Access\n• Experimental Features\n• Lion Debug"
            android:textColor="#000000"
            android:textSize="16sp"
            android:layout_marginTop="10dp"/>

    </LinearLayout>

</LinearLayout>